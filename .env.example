# MedSimulation App Environment Configuration
# Copy this file to .env and update values for your setup

# ═══════════════════════════════════════════════════════════════
# LLM Configuration
# ═══════════════════════════════════════════════════════════════

# LLM Mode: 'local', 'cloud', 'mlc', or 'mock'
# - local: Connect to MedSimulation FastAPI server on same network
# - cloud: Use Modal/Together AI for pay-per-use inference
# - mlc: MLC WebLLM for true on-device inference (requires ~2GB download)
# - mock: Pattern-based responses (no backend required, works offline)
LLM_MODE=local

# ═══════════════════════════════════════════════════════════════
# Local Backend Configuration (used when LLM_MODE=local)
# ═══════════════════════════════════════════════════════════════

# Your MedSimulation FastAPI server URL
# For local development:
#   - Android Emulator: http://10.0.2.2:8000
#   - iOS Simulator: http://localhost:8000
#   - Physical device (same WiFi): http://192.168.x.x:8000
LOCAL_BACKEND_URL=http://localhost:8000

# ═══════════════════════════════════════════════════════════════
# Cloud API Configuration (used when LLM_MODE=cloud)
# ═══════════════════════════════════════════════════════════════

# Modal deployment URL for MedGemma 4B (pay-per-use, ~$0.03/case)
# Deploy using: modal serve /path/to/modal_vllm.py
CLOUD_API_URL=https://your-modal-app-url.modal.run

# Optional: API key if your Modal endpoint requires authentication
CLOUD_API_KEY=your-api-key-here

# ═══════════════════════════════════════════════════════════════
# MLC WebLLM Configuration (used when LLM_MODE=mlc)
# ═══════════════════════════════════════════════════════════════

# MLC Model ID for on-device inference
# Default: Gemma 2B (compatible with MedGemma 4B architecture)
# For MedGemma 4B, convert and host your own:
#   MLC_MODEL_ID=your-username/MedGemma-4B-q4f16_1-MLC
MLC_MODEL_ID=google/gemma-2b-it-q4f16_1-MLC

# Optional: Custom HuggingFace model URL
# MLC_MODEL_URL=https://huggingface.co/google/gemma-2b-it-q4f16_1-MLC

# ═══════════════════════════════════════════════════════════════
# Online Features Configuration (optional)
# ═══════════════════════════════════════════════════════════════

# API URL for PubMed/Wiley case imports and cloud sync
# This is separate from LLM - used for fetching case data
API_BASE_URL=https://your-railway-url.up.railway.app

# Feature flags for online features
FEATURE_PUBMED_IMPORT=true
FEATURE_WILEY_IMPORT=true
FEATURE_CLOUD_SYNC=false
