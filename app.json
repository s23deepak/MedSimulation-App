{
  "expo": {
    "name": "MedSimulation",
    "slug": "medsimulation",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.medsimulation.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow camera access for importing medical images",
        "NSPhotoLibraryUsageDescription": "Allow photo library access for importing medical images"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "package": "com.medsimulation.app",
      "permissions": ["READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "scheme": "medsimulation",
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      }
    }
  }
}
